Algoritmo "03-menor-que-100"


Var
   numero: inteiro
Inicio

      // entrada
      escreval("digite um numero: ")
      leia(numero)
      
      
      // processamento
      
      se (( numero > 0 ) e ( numero < 100 )) entao
          escreval(" seu numero é positivo e menor que 100")
      senao
          escreval(" seu numero é negativo ou maior que 100.")
      fimse


Fimalgoritmo