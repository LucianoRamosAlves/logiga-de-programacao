Algoritmo "01-vacina"


Var
 idade:inteiro


Inicio
       // entrada

      escreval("digite a sua idade")
      leia(idade)


      // processamento
       se (idade >= 67) entao
          escreval(" voce j� pode ser vacinada")
          
       senao

            escreval("aguarde!")
            
       fimse
       
       escreval("fim do programa")

Fimalgoritmo