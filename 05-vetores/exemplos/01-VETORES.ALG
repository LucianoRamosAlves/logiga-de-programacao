Algoritmo "01-vetores"

Var
vet: vetor [1..5] de inteiro
i: inteiro


Inicio
// posso manipular manualmente
vet[1] <- 10
vet[2] <- vet[1] + 101
vet[3] <- - 8
vet[4] <- + 5
vet[5] <- 10 *2

// se eu quizer mostrar ou ler, tenho que percorrer

para i de 1 ate 5 faca
escreval(vet[i])
fimpara


Fimalgoritmo