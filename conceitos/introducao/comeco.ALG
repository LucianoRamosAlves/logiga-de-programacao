Algoritmo "passo_1"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi 
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 25/02/2026
Var
espaco_guardaRoupa: caractere
nome: caractere


Inicio
escreva("olá mundo")
escreval("esse pula linha")
escreval("linha pulada")
espaco_guardaRoupa <- "Toalha"
escreval( espaco_guardaRoupa)

escreval("digite seu nome:")
leia(nome)
escreval("olá, muito prazer " + nome + "!")

Fimalgoritmo