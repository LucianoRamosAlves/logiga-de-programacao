Algoritmo "soma"

Var
   n1, n2, s: inteiro


Inicio
      // fase de entrada
      escreval("digite um numero")
      leia(n1)
      
      escreval("digite outro numero")
      leia(n2)
      
      // fase do processamento
      s <- n1 + n2
      
      // fase da saida
      escreval(" o resultado da soma entre", n1,"+",n2, "é:", s)


Fimalgoritmo