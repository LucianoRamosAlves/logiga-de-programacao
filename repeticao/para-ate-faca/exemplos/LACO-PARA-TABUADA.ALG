Algoritmo "01-laco-para-tabuada"

Var
i, soma, tabuada: inteiro

Inicio
       soma <- 0
       
       escreval(" digite um numero")
       leia(tabuada)
       
      para i de 1 ate 10 faça
               escreval(tabuada, " x ", i, " = ", tabuada*i)
      fimpara
      
            
            


Fimalgoritmo