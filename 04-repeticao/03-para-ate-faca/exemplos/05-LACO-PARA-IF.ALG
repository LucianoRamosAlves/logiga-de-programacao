Algoritmo "01-laco-para-if"

Var
cont, soma: inteiro

Inicio
       soma <- 0
       
       
      para cont de 1 ate 100 faþa
           se (cont % 2 = 0) entao
               soma <- soma + cont
               escreval(soma)
           fimse
      fimpara
      
            
            


Fimalgoritmo