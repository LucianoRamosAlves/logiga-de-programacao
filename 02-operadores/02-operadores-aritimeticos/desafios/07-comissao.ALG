Algoritmo "07-comissao"





Var
 valor_total: real
 comisao: real
 valor_da_comissao: real

Inicio
       // entrada

      escreval("digite valor total")
      leia(valor_total)


      // processamento
       valor_da_comissao <- 5/100 *  valor_total
       
      
      // saida
      
      escreval("sua comiss�o de 5%")
      escreval( " R$: ", valor_da_comissao)


Fimalgoritmo